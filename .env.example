# Copy this file to .env and fill in your values. .env is git-ignored.

# Tailscale API access token — admin panel > Settings > Keys (starts with tskey-api-)
TS_API_TOKEN=

# Your tailnet name, e.g. example.ts.net
# Use "-" to mean the default tailnet of the authenticated token.
TAILNET=

# Port the dashboard listens on
PORT=3000
